# Copy to .env and fill in. Lines starting with # are ignored.
# Existing shell environment variables take precedence over this file.

# --- CoinGecko (strongly recommended; free demo key removes most rate limits) ---
COINGECKO_API_KEY=
# demo or pro
COINGECKO_KEY_TYPE=demo
# blank = auto (8 free / 25 with key)
CG_CALLS_PER_MINUTE=

# --- Notifications (configure at least one) ---
TELEGRAM_BOT_TOKEN=
# One or more chat IDs, comma-separated for multiple recipients:
#   TELEGRAM_CHAT_ID=133428954,987654321
# Each recipient must press Start on the bot first, or they won't receive messages.
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# --- Tuning (optional) ---
RSI_OB=70
RSI_OS=30
RSI_TOP_N=100
RSI_COOLDOWN_HOURS=48
# 0 = alert on every new signal; raise to filter noise
RSI_MIN_CONVICTION=0
# optional path to backtest --export-priors JSON
RSI_REGISTRY_PRIORS=
# 1 = alert on failed/degraded/stale scans
RSI_HEARTBEAT=1
# listener warns if no successful scan is this old
RSI_STALE_SCAN_HOURS=36
RSI_STALE_CHECK_INTERVAL_SEC=1800
# relative paths resolve under the project root
RSI_BACKUP_DIR=backups
# keep newest N DB backups
RSI_BACKUP_KEEP=14
# --status marks the newest backup stale after this
RSI_BACKUP_STALE_HOURS=72
# maintenance.log is added automatically
RSI_LOG_FILES=scan.log,bot.log
RSI_LOG_ROTATE_MAX_BYTES=5242880
RSI_LOG_ROTATE_KEEP=5
RSI_LAUNCHD_SCAN_LABEL=com.nasrenkaraf.rsiscanner
RSI_LAUNCHD_BOT_LABEL=com.nasrenkaraf.rsibot
RSI_MAINTENANCE_LABEL=com.nasrenkaraf.rsimaintenance
RSI_MAINTENANCE_HOUR=3
RSI_MAINTENANCE_MINUTE=45
RSI_MAINTENANCE_LOG=maintenance.log
RSI_UNIVERSE_AUDIT_OUT=universe_hygiene_latest.json
# e.g. fixtures/coingecko_smoke for offline dev smoke
RSI_FIXTURE_DIR=
# PIT research cache; gitignored
RSI_BACKTEST_CACHE_DIR=backtest_cache

# --- Event discovery research (optional; no alerts/paper/orders by default) ---
RSI_EVENT_DISCOVERY_ENABLED=0
RSI_EVENT_DISCOVERY_MODE=research_only
# Manual alias file for real research sources. The checked-in default is empty;
# fixture Make targets explicitly use fixtures/event_discovery/asset_aliases.json.
RSI_EVENT_DISCOVERY_ALIASES_PATH=event_discovery_aliases.json
# Opt-in live research fetches; all default off.
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_LIVE=0
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_API_KEY=
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_API_SECRET=
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_WS_URL=wss://api.binance.com/sapi/wss
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_TOPIC=com_announcement_en
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_RECV_WINDOW_MS=30000
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_LISTEN_SECONDS=5
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_MAX_MESSAGES=20
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_LIVE=0
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_TYPE=new_crypto
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_LIMIT=20
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_TIMEOUT=10
RSI_EVENT_DISCOVERY_CRYPTOPANIC_LIVE=0
RSI_EVENT_DISCOVERY_CRYPTOPANIC_API_TOKEN=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_PUBLIC=1
RSI_EVENT_DISCOVERY_CRYPTOPANIC_FILTER=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_CURRENCIES=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_REGIONS=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_KIND=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_SEARCH=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_TIMEOUT=10
RSI_EVENT_DISCOVERY_GDELT_LIVE=0
RSI_EVENT_DISCOVERY_GDELT_QUERY='("pre-ipo" OR "pre ipo" OR "synthetic exposure" OR "tokenized stock" OR "prediction market" OR "fan token")'
RSI_EVENT_DISCOVERY_GDELT_MAX_RECORDS=50
RSI_EVENT_DISCOVERY_GDELT_TIMEOUT=10
# For a no-key GDELT research cycle:
# make event-fade-gdelt-review-cycle
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_LIVE=0
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_URLS=
# Optional newline-separated RSS/Atom URL file. For a no-key research cycle:
# RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_LIVE=1
# RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_URLS_PATH=fixtures/event_discovery/public_rss_feeds.txt
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_URLS_PATH=
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_TIMEOUT=10
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_LIVE=0
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_BASE_URL=https://gamma-api.polymarket.com/events
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_LIMIT=100
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_TIMEOUT=10
RSI_EVENT_DISCOVERY_COINALYZE_LIVE=0
RSI_EVENT_DISCOVERY_COINALYZE_API_KEY=
RSI_EVENT_DISCOVERY_COINALYZE_SYMBOLS=
RSI_EVENT_DISCOVERY_COINALYZE_AUTO_SYMBOLS=1
RSI_EVENT_DISCOVERY_COINALYZE_BASE_URL=https://api.coinalyze.net/v1/
RSI_EVENT_DISCOVERY_COINALYZE_TIMEOUT=10
RSI_EVENT_DISCOVERY_COINALYZE_HISTORY_INTERVAL=1hour
RSI_EVENT_DISCOVERY_COINALYZE_LOOKBACK_HOURS=24
RSI_EVENT_DISCOVERY_COINALYZE_CONVERT_TO_USD=1
# e.g. fixtures/coingecko_smoke/top_markets.json
RSI_EVENT_DISCOVERY_UNIVERSE_PATH=
RSI_EVENT_DISCOVERY_UNIVERSE_LIVE=0
RSI_EVENT_DISCOVERY_UNIVERSE_FETCH_LIMIT=0
RSI_EVENT_DISCOVERY_CACHE_DIR=event_fade_cache
RSI_EVENT_DISCOVERY_MIN_CLASSIFIER_CONFIDENCE=0.80
RSI_EVENT_DISCOVERY_MIN_EVENT_TIME_CONFIDENCE=0.80
RSI_EVENT_FADE_ALLOW_PROXY_VENUE_TRIGGER=0

# --- Event research alerts (optional; no paper/orders; Telegram send is opt-in) ---
RSI_EVENT_ALERTS_ENABLED=0
RSI_EVENT_ALERT_MODE=research_only
RSI_EVENT_ALERT_MIN_DIGEST_SCORE=55
RSI_EVENT_ALERT_MIN_WATCHLIST_SCORE=70
RSI_EVENT_ALERT_MIN_HIGH_PRIORITY_SCORE=80
RSI_EVENT_ALERT_MAX_DIGEST_ITEMS=10
RSI_EVENT_ALERT_MAX_INSTANT_PER_DAY=3
RSI_EVENT_ALERT_COOLDOWN_HOURS=12
RSI_EVENT_ALERT_ALLOW_PROXY_VENUE=0

# --- Event LLM relationship analysis (optional; fixture/shadow by default) ---
# shadow = diagnose only; advisory = may adjust research-alert tiers with --with-llm.
RSI_EVENT_LLM_ENABLED=0
RSI_EVENT_LLM_MODE=shadow
RSI_EVENT_LLM_PROVIDER=fixture
RSI_EVENT_LLM_MODEL=
RSI_EVENT_LLM_MAX_CANDIDATES_PER_RUN=20
RSI_EVENT_LLM_MIN_PREFILTER_SCORE=45
RSI_EVENT_LLM_REQUIRE_EVIDENCE_QUOTES=1
RSI_EVENT_LLM_CACHE_PATH=
RSI_EVENT_LLM_PROMPT_VERSION=llm_proxy_context_v1
OPENAI_API_KEY=

# --- Event LLM raw-event extraction (optional; fixture/shadow by default) ---
# Extracted assets/catalysts are proposals only until deterministic resolver
# validation matches a known asset universe/alias. No alerts/paper/orders.
RSI_EVENT_LLM_EXTRACTOR_ENABLED=0
RSI_EVENT_LLM_EXTRACTOR_MODE=shadow
RSI_EVENT_LLM_EXTRACTOR_PROVIDER=fixture
RSI_EVENT_LLM_EXTRACTOR_MODEL=
RSI_EVENT_LLM_EXTRACTOR_MAX_EVENTS_PER_RUN=50
RSI_EVENT_LLM_EXTRACTOR_REQUIRE_EVIDENCE_QUOTES=1
RSI_EVENT_LLM_EXTRACTOR_CACHE_PATH=
RSI_EVENT_LLM_EXTRACTOR_PROMPT_VERSION=llm_raw_event_extraction_v1

# --- Event Alpha Radar research phases (disabled until promoted; local artifacts/reports only) ---
RSI_EVENT_MARKET_ENRICHMENT_ENABLED=0
RSI_EVENT_ANOMALY_SCANNER_ENABLED=0
RSI_EVENT_ANOMALY_MIN_RETURN_24H=0.30
RSI_EVENT_ANOMALY_MIN_VOLUME_MCAP=0.25
RSI_EVENT_ANOMALY_MIN_VOLUME_ZSCORE=3.0
RSI_EVENT_ANOMALY_MAX_ASSETS=50
RSI_EVENT_WATCHLIST_ENABLED=0
RSI_EVENT_WATCHLIST_STATE_PATH=
RSI_EVENT_WATCHLIST_EXPIRE_HOURS_AFTER_EVENT=72
RSI_EVENT_ALPHA_ROUTER_ENABLED=0

# --- Universe hygiene (optional) ---
# exclude very low-liquidity market-cap entries
RSI_MIN_VOLUME_TO_MCAP=0.001
# 0 = disabled; useful for smaller custom universes
RSI_MIN_MARKET_CAP_USD=0
# exclude likely bad/stale CoinGecko listings
RSI_MAX_ABS_24H_CHANGE=500
RSI_UNIVERSE_FETCH_MULTIPLIER=2
RSI_UNIVERSE_EXTRA_CANDIDATES=50
