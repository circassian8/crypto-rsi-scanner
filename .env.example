# Copy to .env and fill in. Lines starting with # are ignored.
# Existing shell environment variables take precedence over this file.

# --- CoinGecko (strongly recommended; free demo key removes most rate limits) ---
COINGECKO_API_KEY=
COINGECKO_KEY_TYPE=demo        # demo or pro
CG_CALLS_PER_MINUTE=           # blank = auto (8 free / 25 with key)

# --- Notifications (configure at least one) ---
TELEGRAM_BOT_TOKEN=
# One or more chat IDs, comma-separated for multiple recipients:
#   TELEGRAM_CHAT_ID=133428954,987654321
# Each recipient must press Start on the bot first, or they won't receive messages.
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# --- Tuning (optional) ---
RSI_OB=70
RSI_OS=30
RSI_TOP_N=100
RSI_COOLDOWN_HOURS=48
RSI_MIN_CONVICTION=0           # 0 = alert on every new signal; raise to filter noise
RSI_REGISTRY_PRIORS=           # optional path to backtest --export-priors JSON
RSI_HEARTBEAT=1                # 1 = alert on failed/degraded/stale scans
RSI_STALE_SCAN_HOURS=36        # listener warns if no successful scan is this old
RSI_STALE_CHECK_INTERVAL_SEC=1800
RSI_BACKUP_DIR=backups         # relative paths resolve under the project root
RSI_BACKUP_KEEP=14             # keep newest N DB backups
RSI_BACKUP_STALE_HOURS=72      # --status marks the newest backup stale after this
RSI_LOG_FILES=scan.log,bot.log # maintenance.log is added automatically
RSI_LOG_ROTATE_MAX_BYTES=5242880
RSI_LOG_ROTATE_KEEP=5
RSI_LAUNCHD_SCAN_LABEL=com.nasrenkaraf.rsiscanner
RSI_LAUNCHD_BOT_LABEL=com.nasrenkaraf.rsibot
RSI_MAINTENANCE_LABEL=com.nasrenkaraf.rsimaintenance
RSI_MAINTENANCE_HOUR=3
RSI_MAINTENANCE_MINUTE=45
RSI_MAINTENANCE_LOG=maintenance.log
RSI_UNIVERSE_AUDIT_OUT=universe_hygiene_latest.json
RSI_FIXTURE_DIR=               # e.g. fixtures/coingecko_smoke for offline dev smoke
RSI_BACKTEST_CACHE_DIR=backtest_cache # PIT research cache; gitignored

# --- Event discovery research (optional; no alerts/paper/orders by default) ---
RSI_EVENT_DISCOVERY_ENABLED=0
RSI_EVENT_DISCOVERY_MODE=research_only
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_LIVE=0 # opt-in live research fetch
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_TYPE=new_crypto
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_LIMIT=20
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_TIMEOUT=10
RSI_EVENT_DISCOVERY_UNIVERSE_PATH= # e.g. fixtures/coingecko_smoke/top_markets.json

# --- Universe hygiene (optional) ---
RSI_MIN_VOLUME_TO_MCAP=0.001   # exclude very low-liquidity market-cap entries
RSI_MIN_MARKET_CAP_USD=0       # 0 = disabled; useful for smaller custom universes
RSI_MAX_ABS_24H_CHANGE=500     # exclude likely bad/stale CoinGecko listings
RSI_UNIVERSE_FETCH_MULTIPLIER=2
RSI_UNIVERSE_EXTRA_CANDIDATES=50
