# Copy to .env and fill in. Lines starting with # are ignored.
# Existing shell environment variables take precedence over this file.

# --- CoinGecko (strongly recommended; free demo key removes most rate limits) ---
COINGECKO_API_KEY=
# demo or pro
COINGECKO_KEY_TYPE=demo
# blank = auto (8 free / 25 with key)
CG_CALLS_PER_MINUTE=

# --- Notifications (configure at least one) ---
TELEGRAM_BOT_TOKEN=
# One or more chat IDs, comma-separated for multiple recipients:
#   TELEGRAM_CHAT_ID=133428954,987654321
# Each recipient must press Start on the bot first, or they won't receive messages.
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# --- Tuning (optional) ---
RSI_OB=70
RSI_OS=30
RSI_TOP_N=100
RSI_COOLDOWN_HOURS=48
# 0 = alert on every new signal; raise to filter noise
RSI_MIN_CONVICTION=0
# optional path to backtest --export-priors JSON
RSI_REGISTRY_PRIORS=
# 1 = alert on failed/degraded/stale scans
RSI_HEARTBEAT=1
# listener warns if no successful scan is this old
RSI_STALE_SCAN_HOURS=36
RSI_STALE_CHECK_INTERVAL_SEC=1800
# relative paths resolve under the project root
RSI_BACKUP_DIR=backups
# keep newest N DB backups
RSI_BACKUP_KEEP=14
# --status marks the newest backup stale after this
RSI_BACKUP_STALE_HOURS=72
# maintenance.log is added automatically
RSI_LOG_FILES=scan.log,bot.log
RSI_LOG_ROTATE_MAX_BYTES=5242880
RSI_LOG_ROTATE_KEEP=5
RSI_LAUNCHD_SCAN_LABEL=com.nasrenkaraf.rsiscanner
RSI_LAUNCHD_BOT_LABEL=com.nasrenkaraf.rsibot
RSI_MAINTENANCE_LABEL=com.nasrenkaraf.rsimaintenance
RSI_MAINTENANCE_HOUR=3
RSI_MAINTENANCE_MINUTE=45
RSI_MAINTENANCE_LOG=maintenance.log
RSI_UNIVERSE_AUDIT_OUT=universe_hygiene_latest.json
# e.g. fixtures/coingecko_smoke for offline dev smoke
RSI_FIXTURE_DIR=
# PIT research cache; gitignored
RSI_BACKTEST_CACHE_DIR=backtest_cache

# --- Event discovery research (optional; no alerts/paper/orders by default) ---
# Optional deterministic clock for fixture/review runs; blank = real UTC now.
# CLI commands can also use --event-now 2026-06-15T16:00:00Z.
RSI_EVENT_RESEARCH_NOW=
RSI_EVENT_DISCOVERY_ENABLED=0
RSI_EVENT_DISCOVERY_MODE=research_only
# Manual alias file for real research sources. The checked-in default is empty;
# fixture Make targets explicitly use fixtures/event_discovery/asset_aliases.json.
RSI_EVENT_DISCOVERY_ALIASES_PATH=event_discovery_aliases.json
# Opt-in live research fetches; all default off.
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_LIVE=0
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_API_KEY=
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_API_SECRET=
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_WS_URL=wss://api.binance.com/sapi/wss
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_TOPIC=com_announcement_en
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_RECV_WINDOW_MS=30000
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_LISTEN_SECONDS=5
RSI_EVENT_DISCOVERY_BINANCE_ANNOUNCEMENTS_MAX_MESSAGES=20
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_LIVE=0
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_TYPE=new_crypto
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_LIMIT=20
RSI_EVENT_DISCOVERY_BYBIT_ANNOUNCEMENTS_TIMEOUT=10
RSI_EVENT_DISCOVERY_CRYPTOPANIC_LIVE=0
RSI_EVENT_DISCOVERY_CRYPTOPANIC_API_TOKEN=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_PUBLIC=1
RSI_EVENT_DISCOVERY_CRYPTOPANIC_FILTER=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_CURRENCIES=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_REGIONS=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_KIND=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_SEARCH=
RSI_EVENT_DISCOVERY_CRYPTOPANIC_TIMEOUT=10
RSI_EVENT_DISCOVERY_GDELT_LIVE=0
RSI_EVENT_DISCOVERY_GDELT_QUERY='("pre-ipo" OR "pre ipo" OR "synthetic exposure" OR "tokenized stock" OR "prediction market" OR "fan token")'
RSI_EVENT_DISCOVERY_GDELT_MAX_RECORDS=50
RSI_EVENT_DISCOVERY_GDELT_TIMEOUT=10
# For a no-key GDELT research cycle:
# make event-fade-gdelt-review-cycle
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_LIVE=0
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_URLS=
# Optional newline-separated RSS/Atom URL file. For a no-key research cycle:
# RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_LIVE=1
# RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_URLS_PATH=fixtures/event_discovery/public_rss_feeds.txt
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_URLS_PATH=
RSI_EVENT_DISCOVERY_PROJECT_BLOG_RSS_TIMEOUT=10
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_LIVE=0
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_BASE_URL=https://gamma-api.polymarket.com/events
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_LIMIT=100
RSI_EVENT_DISCOVERY_PREDICTION_MARKET_EVENTS_TIMEOUT=10
RSI_EVENT_DISCOVERY_COINALYZE_LIVE=0
RSI_EVENT_DISCOVERY_COINALYZE_API_KEY=
RSI_EVENT_DISCOVERY_COINALYZE_SYMBOLS=
RSI_EVENT_DISCOVERY_COINALYZE_AUTO_SYMBOLS=1
RSI_EVENT_DISCOVERY_COINALYZE_BASE_URL=https://api.coinalyze.net/v1/
RSI_EVENT_DISCOVERY_COINALYZE_TIMEOUT=10
RSI_EVENT_DISCOVERY_COINALYZE_HISTORY_INTERVAL=1hour
RSI_EVENT_DISCOVERY_COINALYZE_LOOKBACK_HOURS=24
RSI_EVENT_DISCOVERY_COINALYZE_CONVERT_TO_USD=1
# e.g. fixtures/coingecko_smoke/top_markets.json
RSI_EVENT_DISCOVERY_UNIVERSE_PATH=
RSI_EVENT_DISCOVERY_UNIVERSE_LIVE=0
RSI_EVENT_DISCOVERY_UNIVERSE_FETCH_LIMIT=0
RSI_EVENT_DISCOVERY_CACHE_DIR=event_fade_cache
RSI_EVENT_DISCOVERY_MIN_CLASSIFIER_CONFIDENCE=0.80
RSI_EVENT_DISCOVERY_MIN_EVENT_TIME_CONFIDENCE=0.80
RSI_EVENT_FADE_ALLOW_PROXY_VENUE_TRIGGER=0

# --- Event research alerts (optional; no paper/orders; Telegram send is opt-in) ---
RSI_EVENT_ALERTS_ENABLED=0
RSI_EVENT_ALERT_MODE=research_only
RSI_EVENT_ALERT_MIN_DIGEST_SCORE=55
RSI_EVENT_ALERT_MIN_WATCHLIST_SCORE=70
RSI_EVENT_ALERT_MIN_HIGH_PRIORITY_SCORE=80
RSI_EVENT_ALERT_MAX_DIGEST_ITEMS=10
RSI_EVENT_ALERT_MAX_INSTANT_PER_DAY=3
RSI_EVENT_ALERT_COOLDOWN_HOURS=12
RSI_EVENT_ALERT_ALLOW_PROXY_VENUE=0

# --- Event LLM relationship analysis (optional; fixture/shadow by default) ---
# shadow = diagnose only; advisory = may adjust research-alert tiers with --with-llm.
RSI_EVENT_LLM_ENABLED=0
RSI_EVENT_LLM_MODE=shadow
RSI_EVENT_LLM_PROVIDER=fixture
RSI_EVENT_LLM_MODEL=
RSI_EVENT_LLM_OPENAI_TIMEOUT=30
# Relationship-analysis candidate cap. Profile defaults may be overridden locally.
RSI_EVENT_LLM_MAX_CANDIDATES_PER_RUN=20
RSI_EVENT_LLM_MIN_PREFILTER_SCORE=45
RSI_EVENT_LLM_REQUIRE_EVIDENCE_QUOTES=1
# Maximum concurrent live LLM calls for extraction + relationship analysis.
# Keep at 1 for fully sequential debugging. OpenAI notification profiles use
# bounded higher caps (`notify_llm`=12, `notify_llm_deep`=16) inside the same
# per-run/day/cost budgets and notification runtime deadline.
RSI_EVENT_LLM_MAX_PARALLEL_CALLS=1
# OpenAI call-budget caps. 0 means uncapped outside profile defaults.
RSI_EVENT_LLM_MAX_CALLS_PER_RUN=0
RSI_EVENT_LLM_MAX_CALLS_PER_DAY=0
RSI_EVENT_LLM_MAX_ESTIMATED_COST_USD_PER_DAY=0
RSI_EVENT_LLM_ESTIMATED_COST_PER_CALL_USD=0
RSI_EVENT_LLM_BUDGET_LEDGER_PATH=
RSI_EVENT_LLM_CACHE_TTL_HOURS=0
RSI_EVENT_LLM_CACHE_PATH=
RSI_EVENT_LLM_PROMPT_VERSION=llm_proxy_context_v1
OPENAI_API_KEY=

# --- Event LLM raw-event extraction (optional; fixture/shadow by default) ---
# shadow = analyze/report only. advisory = add quote-validated extraction hints
# before deterministic discovery. Extracted assets/catalysts are proposals only
# until deterministic resolver validation matches a known universe/alias.
# No normal RSI alerts, paper trades, live signal writes, or orders.
RSI_EVENT_LLM_EXTRACTOR_ENABLED=0
RSI_EVENT_LLM_EXTRACTOR_MODE=shadow
RSI_EVENT_LLM_EXTRACTOR_PROVIDER=fixture
RSI_EVENT_LLM_EXTRACTOR_MODEL=
RSI_EVENT_LLM_EXTRACTOR_OPENAI_TIMEOUT=30
# Raw-event extraction cap. Profile defaults may be overridden locally.
RSI_EVENT_LLM_EXTRACTOR_MAX_EVENTS_PER_RUN=50
RSI_EVENT_LLM_EXTRACTOR_REQUIRE_EVIDENCE_QUOTES=1
RSI_EVENT_LLM_EXTRACTOR_CACHE_PATH=
RSI_EVENT_LLM_EXTRACTOR_PROMPT_VERSION=llm_raw_event_extraction_v1

# --- Event LLM catalyst-frame analysis (optional; fixture/off by default) ---
# Separates the source's main catalyst from background, historical, negated, and
# corrective context. Validated frames may inform research artifacts only; they
# cannot create TRIGGERED_FADE, trades, paper rows, normal RSI rows, or sends.
RSI_EVENT_LLM_CATALYST_FRAMES_ENABLED=0
RSI_EVENT_LLM_CATALYST_FRAMES_PROVIDER=fixture
RSI_EVENT_LLM_CATALYST_FRAMES_MODEL=
RSI_EVENT_LLM_CATALYST_FRAMES_MAX_ROWS_PER_RUN=20
RSI_EVENT_LLM_CATALYST_FRAMES_MIN_SOURCE_SCORE=0.50
RSI_EVENT_LLM_CATALYST_FRAMES_USE_ENRICHED_TEXT=1
RSI_EVENT_LLM_CATALYST_FRAMES_ONLY_AMBIGUOUS=1
RSI_EVENT_LLM_CATALYST_FRAMES_PROMPT_VERSION=llm_catalyst_frames_v1

# --- Event Alpha Radar research phases (disabled until promoted; local artifacts/reports only) ---
RSI_EVENT_MARKET_ENRICHMENT_ENABLED=0
# Market context older than this is capped in live-style profiles so stale
# snapshots cannot promote WATCHLIST/HIGH_PRIORITY by themselves. Fixture/e2e
# profiles may override the fixture allowance explicitly for offline proof runs.
RSI_EVENT_MARKET_CONTEXT_MAX_AGE_HOURS=6
RSI_EVENT_MARKET_CONTEXT_ALLOW_STALE_FIXTURE=0
RSI_EVENT_MARKET_CONTEXT_STALE_CAP_LEVEL=weak
RSI_EVENT_IMPACT_TAXONOMY_PATH=fixtures/event_discovery/event_impact_taxonomy.json
RSI_EVENT_SOURCE_ENRICHMENT_ENABLED=0
RSI_EVENT_SOURCE_ENRICHMENT_CACHE_DIR=
RSI_EVENT_SOURCE_ENRICHMENT_MAX_CHARS=12000
RSI_EVENT_SOURCE_ENRICHMENT_TIMEOUT_SECONDS=10
RSI_EVENT_SOURCE_ENRICHMENT_MAX_ROWS_PER_RUN=0
RSI_EVENT_SOURCE_ENRICHMENT_MIN_SOURCE_CONFIDENCE=0.55
RSI_EVENT_SOURCE_ENRICHMENT_CLEANER_VERSION=source_enrichment_cleaner_v2
RSI_EVENT_ANOMALY_SCANNER_ENABLED=0
RSI_EVENT_ANOMALY_MIN_RETURN_24H=0.30
RSI_EVENT_ANOMALY_MIN_VOLUME_MCAP=0.25
RSI_EVENT_ANOMALY_MIN_VOLUME_ZSCORE=3.0
RSI_EVENT_ANOMALY_MAX_ASSETS=50
RSI_EVENT_CATALYST_SEARCH_ENABLED=0
RSI_EVENT_CATALYST_SEARCH_PROVIDER=fixture
# Optional comma-list: fixture,gdelt,rss,cryptopanic,polymarket.
RSI_EVENT_CATALYST_SEARCH_PROVIDERS=fixture
RSI_EVENT_CATALYST_SEARCH_FIXTURE_PATH=
RSI_EVENT_CATALYST_SEARCH_MAX_ANOMALIES=10
RSI_EVENT_CATALYST_SEARCH_MAX_QUERIES_PER_ANOMALY=6
RSI_EVENT_CATALYST_SEARCH_MAX_RESULTS_PER_QUERY=5
RSI_EVENT_CATALYST_SEARCH_MIN_ANOMALY_SCORE=60
RSI_EVENT_CATALYST_SEARCH_REQUIRE_LIVE_SOURCE=0
RSI_EVENT_CATALYST_SEARCH_MIN_RESULT_CONFIDENCE=0.50
# Executes source-pack evidence plans for selected near-misses/hypotheses.
# Research-only: writes JSONL artifacts, validates evidence deterministically,
# and cannot send, trade, paper trade, write RSI rows, or create TRIGGERED_FADE.
RSI_EVENT_ALPHA_EVIDENCE_ACQUISITION_ENABLED=0
RSI_EVENT_ALPHA_EVIDENCE_ACQUISITION_MAX_CANDIDATES=10
RSI_EVENT_ALPHA_EVIDENCE_ACQUISITION_MAX_QUERIES=20
RSI_EVENT_ALPHA_EVIDENCE_ACQUISITION_TIMEOUT_SECONDS=8
RSI_EVENT_ALPHA_EVIDENCE_ACQUISITION_FIXTURE_ONLY=0
RSI_EVENT_ALPHA_EVIDENCE_ACQUISITION_PATH=
# Searches source providers for validation evidence around sector/venue/infra
# impact hypotheses. Validation still requires deterministic asset identity.
RSI_EVENT_IMPACT_HYPOTHESIS_SEARCH_ENABLED=0
RSI_EVENT_IMPACT_HYPOTHESIS_MAX_HYPOTHESES=10
RSI_EVENT_IMPACT_HYPOTHESIS_MAX_QUERIES_PER_HYPOTHESIS=4
RSI_EVENT_IMPACT_HYPOTHESIS_MIN_CONFIDENCE=0.55
RSI_EVENT_IMPACT_HYPOTHESIS_MIN_RESULT_CONFIDENCE=0.50
RSI_EVENT_IMPACT_HYPOTHESIS_REQUIRE_VALIDATED_IDENTITY=1
# Candidate-discovery queries search for crypto assets around sector/external
# hypotheses. They are bounded research evidence only; discovered assets must
# still pass deterministic identity/catalyst validation before promotion.
RSI_EVENT_IMPACT_HYPOTHESIS_CANDIDATE_DISCOVERY_ENABLED=0
RSI_EVENT_IMPACT_HYPOTHESIS_MAX_DISCOVERY_QUERIES=10
RSI_EVENT_IMPACT_HYPOTHESIS_MAX_DISCOVERY_RESULTS=5
RSI_EVENT_IMPACT_HYPOTHESIS_STORE_PATH=
RSI_EVENT_INCIDENT_STORE_PATH=
# Store diagnostic/rejected incident observations in event_incidents.jsonl.
# Default 0 keeps live-style stores focused on crypto-relevant
# candidate/canonical/linked incidents; fixture/debug profiles may still write
# diagnostics for tests.
RSI_EVENT_INCIDENT_STORE_DIAGNOSTIC=0
# Store raw_observation/external_context_only incident observations in
# event_incidents.jsonl. Default 0 hides broad unlinked external context such as
# generic prediction-market/political rows from canonical incident artifacts.
RSI_EVENT_INCIDENT_STORE_RAW_OBSERVATIONS=0
RSI_EVENT_WATCHLIST_ENABLED=0
RSI_EVENT_WATCHLIST_STATE_PATH=
RSI_EVENT_WATCHLIST_EXPIRE_HOURS_AFTER_EVENT=72
RSI_EVENT_WATCHLIST_MONITOR_ENABLED=0
# fixture|cycle|coingecko|none. cycle reuses rows already collected by the run.
RSI_EVENT_WATCHLIST_MONITOR_MARKET_SOURCE=cycle
RSI_EVENT_WATCHLIST_MONITOR_MARKET_PATH=
# When MARKET_SOURCE=coingecko and this is 1, active watchlist coin_ids may be
# refreshed with a targeted CoinGecko markets lookup. This is research evidence
# only, fail-soft, and cached per run by the TTL below.
RSI_EVENT_WATCHLIST_MONITOR_TARGETED_LOOKUP=0
RSI_EVENT_WATCHLIST_MONITOR_MAX_ASSETS=50
RSI_EVENT_WATCHLIST_MONITOR_MARKET_CACHE_TTL_SECONDS=900
RSI_EVENT_WATCHLIST_MONITOR_ROUTE_UPDATES=1
# Active watchlist derivative/supply refresh scaffold. `cycle` reuses rows from
# the current Event Alpha run; `fixture` can be supplied by tests/local artifacts;
# `none` disables the channel. These are research hints only.
RSI_EVENT_WATCHLIST_MONITOR_DERIVATIVES_SOURCE=cycle
RSI_EVENT_WATCHLIST_MONITOR_SUPPLY_SOURCE=cycle
RSI_EVENT_WATCHLIST_MONITOR_ENRICHMENT_MAX_ASSETS=50
RSI_EVENT_ALPHA_ROUTER_ENABLED=0
RSI_EVENT_ALPHA_ROUTER_DAILY_DIGEST_ENABLED=1
RSI_EVENT_ALPHA_ROUTER_INSTANT_ENABLED=1
RSI_EVENT_ALPHA_ROUTER_MAX_DIGEST_ITEMS=20
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_DIGEST_ENABLED=0
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_DIGEST_MAX_ITEMS=5
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_MAX_ITEMS=5
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_DIGEST_MIN_SCORE=65
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_MIN_OPPORTUNITY_SCORE=65
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_MIN_FINAL_SCORE=65
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_REQUIRE_EXTERNAL_OR_DIRECT_EVENT=1
# Validated hypothesis digest quality gates. By default weak catalyst/token
# co-occurrence remains local-only unless the evidence explains the impact path.
RSI_EVENT_ALPHA_VALIDATED_HYPOTHESIS_REQUIRE_IMPACT_PATH=1
RSI_EVENT_ALPHA_WEAK_VALIDATED_LOCAL_ONLY=1
RSI_EVENT_ALPHA_ALLOW_WEAK_PATH_WITH_MARKET_CONFIRMATION=1
RSI_EVENT_ALPHA_BLOCK_GENERIC_COOCCURRENCE_DIGEST=1
# Near-miss refresh is research-only. notify_llm_quality/notify_llm_deep enable
# it by profile so near-promotion candidates can get bounded market evidence
# before final routing. It cannot create trades, paper rows, normal RSI rows, or
# LLM/provider-created TRIGGERED_FADE.
RSI_EVENT_ALPHA_NEAR_MISS_MARKET_REFRESH_ENABLED=0
RSI_EVENT_ALPHA_NEAR_MISS_MARKET_REFRESH_MAX_ASSETS=20
RSI_EVENT_ALPHA_NEAR_MISS_MARKET_REFRESH_TIMEOUT_SECONDS=5
# Alias names for the same research-only refresh path; live-style profiles may
# enable them to re-check stale/missing market context before final routing.
RSI_EVENT_ALPHA_TARGETED_MARKET_REFRESH_ENABLED=0
RSI_EVENT_ALPHA_TARGETED_MARKET_REFRESH_MAX_ASSETS=20
RSI_EVENT_ALPHA_TARGETED_MARKET_REFRESH_TIMEOUT_SECONDS=5
RSI_EVENT_ALPHA_TARGETED_MARKET_REFRESH_PROFILE_ALLOW_FIXTURE=0
RSI_EVENT_ALPHA_NEAR_MISS_THRESHOLD_POINTS=10
RSI_EVENT_ALPHA_ROUTER_MAX_HIGH_PRIORITY_PER_DAY=3
RSI_EVENT_ALPHA_ROUTER_PER_KEY_COOLDOWN_HOURS=12
RSI_EVENT_ALPHA_ROUTER_ALERT_ON_SCORE_JUMP=1
RSI_EVENT_ALPHA_ROUTER_SCORE_JUMP_THRESHOLD=10
RSI_EVENT_ALPHA_ROUTER_ALERT_ON_NEW_INDEPENDENT_SOURCE=1
RSI_EVENT_ALPHA_ROUTER_ALERT_ON_EVENT_TIME_UPGRADE=1
RSI_EVENT_ALPHA_ROUTER_ALERT_ON_DERIVATIVES_CROWDING_UPGRADE=1
RSI_EVENT_ALPHA_ROUTER_ALERT_ON_CLUSTER_CONFIDENCE_UPGRADE=1
# Day-1 Event Alpha notification lanes. These are research-only sends and are
# separate from the generic event-alert digest cooldown. Actual delivery still
# requires --event-alert-send plus RSI_EVENT_ALERTS_ENABLED=1 and Telegram config.
RSI_EVENT_ALPHA_NOTIFY_SCOPE=global
RSI_EVENT_ALPHA_NOTIFY_DAILY_DIGEST_COOLDOWN_HOURS=12
RSI_EVENT_ALPHA_NOTIFY_INSTANT_COOLDOWN_HOURS=1
RSI_EVENT_ALPHA_NOTIFY_MAX_INSTANT_PER_DAY=3
RSI_EVENT_ALPHA_NOTIFY_HEALTH_HEARTBEAT_ENABLED=1
RSI_EVENT_ALPHA_NOTIFY_HEALTH_HEARTBEAT_COOLDOWN_HOURS=24
# notify_no_key/notify_llm notification profiles override heartbeat/exploratory/
# digest cooldowns to 0 so every clean scheduled notification run sends operator
# output. Keep the global defaults conservative for other profiles unless you
# intentionally want per-run delivery.
# Exploratory digest surfaces top suppressed/store-only rows for operator
# learning during notification burn-in. It is not alertable and not a trade signal.
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_ENABLED=0
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_MAX_ITEMS=10
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_MIN_SCORE=0
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_COOLDOWN_HOURS=24
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_INCLUDE_REJECTION_REASONS=1
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_INCLUDE_RAW_EVIDENCE=1
RSI_EVENT_ALPHA_EXPLORATORY_DIGEST_INCLUDE_CONTROLS=0
# Notification quality mode: exploratory_only sends heartbeat/exploratory
# learning digests, validated_digest sends validated digest/high-priority lanes,
# high_quality_only sends only high-priority or deterministic triggered-fade
# research routes. This never changes router scoring or creates trades.
RSI_EVENT_ALPHA_NOTIFICATION_QUALITY_MODE=validated_digest
# Notification burn-in uses these to fail soft on slow/DNS-failing live providers
# such as CoinGecko market enrichment, then writes degraded heartbeat/run rows.
# OpenAI notification profiles override the runtime cap to 600s so deeper
# bounded-parallel LLM runs can finish without blocking forever.
RSI_EVENT_ALPHA_NOTIFY_MAX_RUNTIME_SECONDS=120
RSI_EVENT_ALPHA_NOTIFY_PROVIDER_TIMEOUT_SECONDS=5
RSI_EVENT_ALPHA_NOTIFY_MAX_PROVIDER_FAILURES_BEFORE_SKIP=1
RSI_EVENT_ALPHA_NOTIFY_FAST_FAIL_ON_DNS=1
RSI_EVENT_ALPHA_NOTIFY_ALLOW_PARTIAL_RESULTS=1
# Stale/future fixed RSI_EVENT_RESEARCH_NOW blocks actual notification sends
# unless this explicit override is set. Leave disabled for production clock safety.
RSI_EVENT_ALPHA_ALLOW_FIXED_NOW_FOR_NOTIFY=0
# Emergency notification pause. The CLI pause file is preferred for normal use:
#   python3 main.py --event-alpha-pause-notifications --event-alpha-profile notify_no_key --reason "..."
# Env pause is useful for launchd/cron-wide stops. Paused runs still write
# discovery/report artifacts and blocked delivery rows with notifications_paused.
RSI_EVENT_ALPHA_NOTIFICATIONS_PAUSED=0
RSI_EVENT_ALPHA_NOTIFICATIONS_PAUSE_REASON=
# Per-profile notification run lock: prevents overlapping scheduled notify cycles
# from double-sending or racing on lane cooldown state. The lock file lives at
# <namespace>/event_alpha_notify.lock; stale locks (older than the stale window,
# or a dead holder PID on this host) are recovered. Set ALLOW_OVERLAP=1 only to
# intentionally run concurrent notify cycles.
RSI_EVENT_ALPHA_NOTIFY_LOCK_ENABLED=1
RSI_EVENT_ALPHA_NOTIFY_LOCK_STALE_MINUTES=30
RSI_EVENT_ALPHA_NOTIFY_ALLOW_OVERLAP=0
# Idempotent notification delivery ledger: records planned/sending/delivered/
# partial_delivered/failed/skipped_duplicate/skipped_in_flight/blocked per lane.
# Dedupe uses stable lane keys when available (alert ids, heartbeat day/status,
# daily digest day/bucket) and keeps exact content_hash for audit/back-compat.
# Partial delivery marks lane cooldown by default so successful recipients are
# not resent the same alert; set PARTIAL_MARKS_COOLDOWN=0 to retry partial sends
# without marking cooldown. Path defaults to
# <namespace>/event_alpha_notification_deliveries.jsonl.
# notify_no_key disables stable content dedupe so every clean run can deliver;
# lock and in-flight guards still prevent overlapping sends.
RSI_EVENT_ALPHA_NOTIFICATION_DEDUPE_BY_CONTENT=1
RSI_EVENT_ALPHA_NOTIFICATION_DEDUPE_WINDOW_HOURS=24
RSI_EVENT_ALPHA_NOTIFICATION_IN_FLIGHT_GRACE_MINUTES=10
RSI_EVENT_ALPHA_NOTIFICATION_PARTIAL_MARKS_COOLDOWN=1
# RSI_EVENT_ALPHA_NOTIFICATION_DELIVERIES_PATH=  # optional explicit override
# `--event-alpha-cycle --event-alert-send` sends only router-approved
# escalations from this layer. Broad event digests still use --event-alert-report.
# Profiled Event Alpha artifacts are isolated under
# RSI_EVENT_ALPHA_ARTIFACT_BASE_DIR/RSI_EVENT_ALPHA_ARTIFACT_NAMESPACE unless a
# specific path override below is set. Run modes: test, fixture, replay,
# burn_in, operational. Test/fixture/replay rows are ignored by burn-in/readiness
# reports unless --event-alpha-include-test-artifacts is passed. Legacy/default
# rows without run_mode/artifact_namespace are ignored by operational reports
# unless --event-alpha-include-legacy-artifacts is passed for migration review.
# Use PROFILE=notify_llm_quality plus make event-alpha-notify-llm-quality-scheduled
# for a fresh live-style, no-send signal-quality artifact run.
RSI_EVENT_ALPHA_ARTIFACT_BASE_DIR=event_fade_cache
RSI_EVENT_ALPHA_ARTIFACT_NAMESPACE=
RSI_EVENT_ALPHA_RUN_MODE=
RSI_EVENT_ALPHA_FEEDBACK_PATH=
# Local research-only alert snapshot JSONL used by --event-alpha-alerts-report.
RSI_EVENT_ALPHA_ALERT_STORE_PATH=
# Local day-1 notification summary JSONL used by --event-alpha-notification-runs-report.
RSI_EVENT_ALPHA_NOTIFICATION_RUNS_PATH=
# Leave blank for profile/namespace-aware reports and inbox:
#   python3 main.py --event-alpha-notification-inbox --event-alpha-profile notify_no_key
# Set only for an intentional explicit path override.
# Local Event Alpha cycle run ledger for --event-alpha-runs-report.
RSI_EVENT_ALPHA_RUN_LEDGER_PATH=
# Local missed-opportunity JSONL written/read by --event-alpha-missed-report and calibration.
RSI_EVENT_ALPHA_MISSED_PATH=
# Reviewable priors export path. Generated priors are not applied automatically.
RSI_EVENT_ALPHA_PRIORS_PATH=
# Optional filled-outcome artifact path used by burn-in/report contexts.
RSI_EVENT_ALPHA_OUTCOMES_PATH=
# Opt-in only: apply bounded calibration priors to research alert ranking.
RSI_EVENT_ALPHA_APPLY_PRIORS=0
RSI_EVENT_ALPHA_PRIORS_MIN_MULTIPLIER=0.70
RSI_EVENT_ALPHA_PRIORS_MAX_MULTIPLIER=1.30
# Provider health circuit-breaker state for live event-source, enrichment, and
# catalyst-search providers. Backoff skips providers fail-soft in research runs.
RSI_EVENT_PROVIDER_HEALTH_PATH=
RSI_EVENT_PROVIDER_MAX_CONSECUTIVE_FAILURES=3
RSI_EVENT_PROVIDER_BACKOFF_MINUTES=30
RSI_EVENT_PROVIDER_FAIL_FAST_ON_DNS=1
# One-shot notification force-run option. Prefer provider-health reset for a
# persistent clear; this only bypasses provider backoff for the current run and
# leaves the health file intact unless the provider fails again.
RSI_EVENT_ALPHA_IGNORE_PROVIDER_BACKOFF=0
# Markdown daily brief output path.
RSI_EVENT_ALPHA_DAILY_BRIEF_PATH=
# Proposed eval-case export directory. Canonical fixtures are never modified automatically.
RSI_EVENT_ALPHA_PROPOSED_EVAL_CASES_DIR=
# Markdown research-card output directory.
RSI_EVENT_RESEARCH_CARDS_DIR=
# Auto-write selected research cards during --event-alpha-cycle. Off by default.
RSI_EVENT_RESEARCH_CARDS_AUTO_WRITE=0
RSI_EVENT_RESEARCH_CARDS_WRITE_TIERS=HIGH_PRIORITY_WATCH,TRIGGERED_FADE,WATCHLIST
# Burn-in checklist/report commands resolve artifact paths from the selected
# --event-alpha-profile and namespace first, then print readiness diagnostics
# only; they do not enable sends or mutate thresholds.
# Use `main.py --event-alpha-preflight --event-alpha-profile no_key_live` before
# scheduled runs to check paths, providers, LLM budget/key state, and send guards.
# Strict artifact-doctor mode escalates legacy snapshot mismatches, mixed
# namespaces, missing provider health, and unknown feedback/outcome IDs to
# blockers. Keep off during migration; enable for burn-in gates.
RSI_EVENT_ALPHA_ARTIFACT_DOCTOR_STRICT=0
# Health guard thresholds for daily burn-in freshness. Optional profile guard
# should be set by Make target/profile wrapper rather than globally unless you
# want every health check to require that profile.
RSI_EVENT_ALPHA_MAX_RUN_AGE_HOURS=6
RSI_EVENT_ALPHA_MAX_SUCCESS_AGE_HOURS=12
RSI_EVENT_ALPHA_HEALTH_REQUIRE_PROFILE=
# Research snapshot retention policy: all, non_store, routed, alertable,
# sampled_controls. Defaults to all; sampled_controls keeps non-store rows plus
# a small capped sample of STORE_ONLY controls for QA.
RSI_EVENT_ALPHA_SNAPSHOT_POLICY=all
RSI_EVENT_ALPHA_SNAPSHOT_SAMPLED_CONTROLS=25
# Retention/pruning defaults for research artifacts. Pruning is dry-run unless
# --confirm is passed.
RSI_EVENT_ALPHA_RETENTION_DAYS_RUNS=90
RSI_EVENT_ALPHA_RETENTION_DAYS_ALERTS=180
RSI_EVENT_ALPHA_RETENTION_DAYS_CARDS=180
RSI_EVENT_ALPHA_RETENTION_KEEP_EVAL_CASES=1
# Local-only operational reports:
# --event-alpha-status, --event-watchlist-monitor, --event-alpha-calibration-report,
# and --event-research-card never trade, paper trade, or write live signal rows.

# --- Universe hygiene (optional) ---
# exclude very low-liquidity market-cap entries
RSI_MIN_VOLUME_TO_MCAP=0.001
# 0 = disabled; useful for smaller custom universes
RSI_MIN_MARKET_CAP_USD=0
# exclude likely bad/stale CoinGecko listings
RSI_MAX_ABS_24H_CHANGE=500
RSI_UNIVERSE_FETCH_MULTIPLIER=2
RSI_UNIVERSE_EXTRA_CANDIDATES=50
