{
  "schema_version": "lean_crypto_radar_product_contract_v1",
  "status": "active_product_rebuild",
  "product": "Lean Crypto Radar V1",
  "default_operator_product": true,
  "implementation_state": {
    "bybit_universe_and_store_foundation": "implemented",
    "scan_and_idea_detection": "implemented",
    "default_no_send_operator_cycle": "implemented",
    "dashboard": "implemented",
    "telegram_preview": "implemented",
    "calendar": "implemented",
    "outcomes": "implemented",
    "system_health": "implemented"
  },
  "venue": "bybit",
  "instrument_type": "usdt_perpetual",
  "universe": {
    "top_liquid_limit": 200,
    "liquidity_rank_basis": "coingecko_total_volume_usd_24h_desc_after_shared_hygiene",
    "requires_confirmed_active_bybit_instrument": true,
    "manual_watchlist_enabled": true,
    "unverified_watchlist_policy": "visible_blocked_unverified"
  },
  "cadence_minutes": {
    "default": 20,
    "minimum": 15,
    "maximum": 30
  },
  "default_operator_workflow": {
    "read_only_status_command": "make lean-radar",
    "no_send_cycle_command": "make lean-radar-cycle",
    "dashboard_command": "make lean-radar-dashboard",
    "telegram_preview_command": "make lean-radar-telegram-preview",
    "cycle_stages": [
      "cadence_gated_market_scan",
      "point_in_time_outcome_refresh",
      "operator_health_refresh",
      "telegram_preview"
    ],
    "maximum_provider_calls": 1,
    "requires_existing_provider_authorization": true,
    "telegram_delivery_invoked": false
  },
  "market_scan": {
    "live_provider": "coingecko_coins_markets",
    "live_order": "volume_desc",
    "live_request_bound": 1,
    "direct_return_fields": [
      "1h_percent_points",
      "24h_percent_points",
      "7d_percent_points"
    ],
    "proxy_fields": {
      "rsi_14": "wilder_14_on_untimestamped_coingecko_7d_sparkline_points"
    },
    "unavailable_without_timestamped_bars": [
      "exact_4h_return"
    ],
    "rolling_volume_baseline_minimum_samples": 8,
    "cold_start_attention_proxy": "cross_sectional_turnover_zscore",
    "one_setup_per_asset": true,
    "atomic_snapshot_idea_outcome_placeholder_health_write": true,
    "provisional_rules_are_win_probabilities": false
  },
  "calendar": {
    "runtime_store": "sqlite_calendar_events",
    "live_provider_call": false,
    "genuine_local_import_confirmation_required": true,
    "exact_source_bytes_sha256": true,
    "supported_categories": [
      "fomc",
      "cpi",
      "ppi",
      "pce",
      "employment_report",
      "gdp",
      "crypto_unlock",
      "exchange_listing",
      "exchange_delisting",
      "protocol_event"
    ],
    "macro_scope": "global_context",
    "crypto_scope": "exact_affected_symbol_only",
    "may_raise_risk_or_urgency": true,
    "may_shorten_existing_idea_expiry": true,
    "may_create_directional_bias": false,
    "may_create_idea_without_market_setup": false
  },
  "outcomes": {
    "horizons": [
      "1h",
      "4h",
      "24h",
      "3d"
    ],
    "source": "retained_point_in_time_market_snapshots",
    "endpoint_policy": "first_observation_at_or_after_target_within_45_minutes",
    "missing_endpoint_policy": "pending_then_unresolved_without_backfill",
    "relative_benchmarks": [
      "bitcoin",
      "ethereum"
    ],
    "mfe_mae_policy": "directional_review_only_neutral_remains_unavailable",
    "result_vocabulary": [
      "continued",
      "reversed",
      "failed_quickly",
      "risk_warning_validated",
      "inconclusive"
    ],
    "descriptive_move_band_percent_points": 2.0,
    "failed_quickly_1h_band_percent_points": 3.0,
    "automatic_threshold_changes": false,
    "human_labels_required": false,
    "provider_call": false
  },
  "system_health": {
    "persisted_runtime_projection": true,
    "separates_current_authorization_from_last_provider_result": true,
    "reports": [
      "last_scan",
      "next_scan",
      "provider_status",
      "bybit_universe",
      "coingecko",
      "data_freshness",
      "current_authorization",
      "current_provider_call_eligibility",
      "no_send",
      "telegram_mode",
      "telegram_preview_and_send_readiness",
      "last_telegram_delivery",
      "bounded_errors",
      "next_safe_command"
    ],
    "provider_call": false,
    "telegram_send": false
  },
  "surfaces": {
    "dashboard_priority": "primary_equal",
    "telegram_priority": "primary_equal",
    "dashboard_page_limit": 6,
    "dashboard_pages": [
      "today",
      "ideas",
      "market",
      "calendar",
      "outcomes",
      "system_health"
    ],
    "dashboard_runtime": {
      "source": "single_sqlite_runtime",
      "methods": [
        "GET",
        "HEAD"
      ],
      "browser_writes": false,
      "browser_environment_authorization_inspection": false,
      "provider_calls": false,
      "telegram_sends": false,
      "current_ideas_require_fresh_complete_scan": true,
      "stale_or_incomplete_scan_behavior": "hide_current_ideas_preserve_history",
      "default_host": "127.0.0.1",
      "default_port": 8766,
      "provenance_badges": [
        "live_no_send",
        "imported_snapshot",
        "fixture"
      ]
    },
    "telegram": {
      "message_types": [
        "urgent_review",
        "watchlist_update",
        "daily_digest",
        "risk_calendar"
      ],
      "projection_of_canonical_ideas": true,
      "current_ideas_require_fresh_complete_scan": true,
      "calendar_context_remains_independently_eligible": true,
      "preview_read_only": true,
      "preview_provider_calls": false,
      "preview_database_writes": false,
      "preview_sends": false,
      "visible_family_dedupe": true,
      "material_score_delta": 8.0,
      "maximum_group_items": 4,
      "hard_daily_urgent_cap": null,
      "market_wide_grouping": true,
      "state_consumed_only_after_full_delivery_success": true,
      "overlapping_send_lease": "sqlite_expiring_local_lease",
      "send_requires": [
        "non_fixture_trusted_due_items",
        "existing_telegram_configuration",
        "RSI_EVENT_ALERTS_ENABLED=1",
        "CONFIRM=1"
      ],
      "stores_token_or_recipient_values": false,
      "market_provider_calls": false
    },
    "telegram_default": "no_send"
  },
  "idea_types": [
    "market_breakout_long",
    "relative_strength_long",
    "pullback_or_mean_reversion",
    "rapid_market_anomaly",
    "exhaustion_or_fade_review",
    "selloff_or_risk_warning",
    "calendar_risk",
    "dashboard_watch",
    "diagnostic"
  ],
  "routes": [
    "urgent_review",
    "watchlist",
    "daily_digest",
    "dashboard_only",
    "risk_calendar",
    "diagnostic_hidden"
  ],
  "scores": [
    "actionability",
    "confidence",
    "risk",
    "urgency"
  ],
  "urgent_notification_policy": {
    "hard_daily_cap": null,
    "visible_family_dedupe": true,
    "cooldown_for_unchanged_updates": true,
    "material_change_required_for_repeat": true,
    "market_wide_grouping": true
  },
  "catalyst_policy": {
    "known_catalyst_required": false,
