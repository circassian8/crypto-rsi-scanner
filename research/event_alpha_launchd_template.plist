<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.eventalpha.burnin</string>

  <key>Disabled</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/make</string>
    <string>event-alpha-burn-in-no-key</string>
    <string>PYTHON=__PYTHON__</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/event_alpha_burnin.out.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/event_alpha_burnin.err.log</string>
</dict>
</plist>
